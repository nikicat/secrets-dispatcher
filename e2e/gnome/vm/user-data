#cloud-config
# Provisions an Ubuntu cloud image (any UBUNTU_SERIES run.sh supports — same
# package set on 24.04 and 26.04) into a minimal real-GNOME desktop:
# gdm3 + gnome-shell + gnome-keyring with autologin for the e2e user. This is
# the Tier-2 fidelity environment — the only place gnome-keyring's real
# start/re-grab vectors (systemd user units, XDG autostart, D-Bus activation,
# gnome-session) are honestly reproduced. See docs/plans/onboarding-and-e2e.md.
#
# @SSH_PUBKEY@ is substituted by run.sh at seed-build time.

users:
  - name: e2e
    gecos: E2E Test User
    groups: [adm, sudo]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # Throwaway test VM — plain text is fine and keeps the password greppable
    # for VT logins during interactive debugging.
    plain_text_passwd: tier2-password
    ssh_authorized_keys:
      - "@SSH_PUBKEY@"

package_update: true
packages:
  - gdm3
  - gnome-session
  - gnome-shell
  - gnome-keyring
  - dbus-user-session
  - libsecret-tools
  - seahorse
  # gjs is a fidelity fix, not just a demo dep: on GNOME 46 the notification
  # daemon (org.gnome.Shell.Notifications) and the screencast service
  # (org.gnome.Shell.Screencast) are D-Bus-activated gjs processes. A stock
  # Ubuntu desktop ships gjs; without it this VM has NO org.freedesktop.
  # Notifications name at all, and demo.sh cannot record the screen.
  - gjs
  # demo.sh (screen-recorded product demos) additions: a visible terminal to
  # type into, tmux to drive it, and a desktop wallpaper so the recording
  # reads as a real desktop. Go comes from an upstream tarball (runcmd
  # below), NOT golang-go: the apt toolchain is older than go.mod's
  # requirement, and the GOTOOLCHAIN auto-switch prints a distracting
  # "requires go >= X; switching to goX.Y.Z" line on camera.
  - gnome-terminal
  - tmux
  - ubuntu-wallpapers

write_files:
  # gdm autologin for the e2e user — the realistic "stock desktop" case the
  # dispatcher will meet in the wild (and the hard one for keyring unlock).
  - path: /etc/gdm3/custom.conf
    content: |
      [daemon]
      AutomaticLoginEnable=true
      AutomaticLogin=e2e
  # Skip gnome-initial-setup so the session comes up unattended.
  - path: /home/e2e/.config/gnome-initial-setup-done
    defer: true
    owner: e2e:e2e
    content: "yes"

runcmd:
  - systemctl set-default graphical.target
  # Linger so the e2e user's systemd user instance (and user bus) survives
  # SSH session churn during tests.
  - loginctl enable-linger e2e
  # Current stable Go from upstream (see the packages comment). The weekly
  # CI cache rotation re-provisions, so this tracks Go releases closely
  # enough to stay >= go.mod's requirement.
  - GOV=$(curl -fsSL 'https://go.dev/VERSION?m=text' | head -1) && curl -fsSL "https://go.dev/dl/${GOV}.linux-amd64.tar.gz" | tar -C /usr/local -xz
  - printf 'export PATH=$PATH:/usr/local/go/bin\n' > /etc/profile.d/go-path.sh
  - touch /var/tmp/cloud-init-ready

power_state:
  mode: poweroff
  message: provisioning complete
  condition: true
