post_install() {
  echo ":: To get started:"
  echo "   1. Copy the example config:"
  echo "      mkdir -p ~/.config/secrets-dispatcher"
  echo "      cp /usr/share/secrets-dispatcher/config.yaml.example ~/.config/secrets-dispatcher/config.yaml"
  echo ""
  echo "   2. Install and start the systemd user service:"
  echo "      secrets-dispatcher service install --start"
  echo ""
  echo "   3. Open the web UI:"
  echo "      secrets-dispatcher login"
}

post_upgrade() {
  post_install
}
